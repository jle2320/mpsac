<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MPSAC</title>
<link rel="icon" href="/images/logo.png" type="image/png">
<link rel="stylesheet" href="/css/output.css">
<link rel="stylesheet" href="/css/main.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  * { font-family: 'DM Sans', sans-serif; }
  h1,h2,h3,.font-display { font-family: 'Playfair Display', serif; }

  /* Grain overlay */
  body::before {
    content:'';
    position:fixed;
    inset:0;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events:none;
    z-index:9999;
    opacity:0.4;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width:6px; }
  ::-webkit-scrollbar-track { background:#f2f9f2; }
  ::-webkit-scrollbar-thumb { background:#3a9134; border-radius:3px; }

  /* Hero video overlay */
  .hero-overlay { background: linear-gradient(135deg, rgba(24,61,23,0.82) 0%, rgba(122,53,18,0.45) 100%); }

  /* Leaf float animation */
  @keyframes leafFloat {
    0%,100% { transform: translateY(0) rotate(-3deg); }
    50%      { transform: translateY(-18px) rotate(3deg); }
  }
  .leaf-float { animation: leafFloat 5s ease-in-out infinite; }

  /* Card hover overlay */
  .product-card .overlay { opacity:0; transition: opacity 0.3s ease; }
  .product-card:hover .overlay { opacity:1; }
  .product-card:hover img { transform: scale(1.07); }
  .product-card img { transition: transform 0.4s ease; }

  /* Filter chip active */
  .filter-chip.active { background:#2d7429; color:#fff; border-color:#2d7429; }

  /* Stagger fade-in */
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(32px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .fade-up { animation: fadeUp 0.6s ease forwards; }
  .delay-1 { animation-delay:0.1s; }
  .delay-2 { animation-delay:0.2s; }
  .delay-3 { animation-delay:0.3s; }
  .delay-4 { animation-delay:0.4s; }

  /* Mobile nav pulse */
  .nav-icon.active svg { stroke:#2d7429; }

  /* Marquee */
  @keyframes marquee { from { transform:translateX(0); } to { transform:translateX(-50%); } }
  .marquee-inner { animation: marquee 22s linear infinite; }

  /* Range slider */
  input[type=range] { accent-color: #2d7429; }


    .form-label{display:block;font-size:.72rem;font-weight:600;color:#8fce8a;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;}
  .form-label .req{color:#f97316;margin-left:2px;}
  .form-label .hint{color:#3a9134;font-weight:400;normal-case;text-transform:none;margin-left:6px;font-size:.68rem;}

  .form-input{
    width:100%;
    background:rgba(255,255,255,.055);
    border:1.5px solid rgba(255,255,255,.09);
    border-radius:12px;
    padding:11px 14px;
    color:#e0f2df;
    font-size:.85rem;
    transition:border-color .2s,background .2s,box-shadow .2s;
  }
  .form-input::placeholder{color:rgba(143,206,138,.38);}
  .form-input:focus{outline:none;border-color:#fbbf24;background:rgba(255,255,255,.085);box-shadow:0 0 0 3px rgba(251,191,36,.12);}
  .form-input:invalid:not(:placeholder-shown){border-color:rgba(249,115,22,.5);}
  select.form-input option{background:#1f4b1d;color:#e0f2df;}
  textarea.form-input{resize:vertical;min-height:120px;line-height:1.6;}
</style>
</head>
<body class="bg-forest-50 text-forest-900 pb-20 md:pb-0" data-user='<%- JSON.stringify(activeUser || null) %>' >



<!-- ═══════════════════════════════════════════
     DESKTOP NAV
════════════════════════════════════════════ -->
<div id="modal" class="modal-backdrop" role="dialog" aria-modal="true">
  <div class="modal-box" id="modalBox">
    <div id="modalContent"></div>
  </div>
</div>

<div id="toast">
  <span id="toast-msg"></span>
</div>




<!-- ═══════════════════════════════════════════
     DESKTOP NAV
════════════════════════════════════════════ -->
<header class="hidden md:block sticky top-0 z-50 bg-forest-900/95 backdrop-blur-md border-b border-forest-700">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2.5">
      <div class="w-9 h-9 bg-harvest-400 rounded-xl flex items-center justify-center shrink-0 shadow-lg shadow-harvest-900/30">
        <img src="/images/logo.png" />
      </div>
      <span class="font-display text-xl text-white font-bold tracking-wide">MP<span class="text-harvest-400">SAC</span></span>
    </a>



    <!-- Right actions -->
    <div class="flex items-center gap-4">
      
      <!-- Orders -->
      <a href="/" class="text-forest-300 hover:text-harvest-300 transition flex items-center gap-1.5 text-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Home
      </a>

      <% if (activeUser) { %>
        <!-- Account -->
      <a href="/account" class="text-forest-300 hover:text-harvest-300 transition flex items-center gap-1.5 text-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Account
      </a>
      <% } else { %>
        <a href="/account/login" class="text-green-700 hover:text-orange-500 transition flex items-center gap-1.5 text-sm font-medium">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
          <polyline points="10 17 15 12 10 7" />
          <line x1="15" y1="12" x2="3" y2="12" />
        </svg>
        Sign-in
      </a>
      <% } %>
  
      
      <!-- Orders -->
      <a href="<%= activeUser ? '/orders' : '/account/login' %>" class="text-forest-300 hover:text-harvest-300 transition flex items-center gap-1.5 text-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
        Orders
      </a>
      <!-- Cart -->
      <a href="<%= activeUser ? '/myCart' : '/account/login' %>" class="relative bg-harvest-400 hover:bg-harvest-500 text-forest-900 font-semibold text-sm px-4 py-2 rounded-full transition flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        Cart
        <span class="cartBadge hidden absolute -top-1.5 -right-1.5 bg-terra-500 text-white text-xs w-5 h-5 rounded-full flex items-center justify-center font-bold"></span>
      </a>
    </div>
  </div>
</header>

