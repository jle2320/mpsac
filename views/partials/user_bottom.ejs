<!-- Sign-in Modal Overlay -->
<div class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
    <!-- Backdrop -->
    <div class="modal-backdrop absolute inset-0 bg-stone-900/60 backdrop-blur-sm"></div>
    
    <!-- Modal Content Card -->
    <div class="modal-card relative bg-white w-full max-w-md rounded-2xl shadow-2xl overflow-hidden transform scale-95 opacity-0 transition-all duration-300 ease-out">
        <div class="p-8">
            <div class="text-center mb-6">
                <h2 class="text-2xl font-bold text-gray-800">Welcome Back</h2>
            </div>

            <form class="space-y-4" id="signInForm" autocomplete="off" >
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                    <input id="inputPhoneNumber" type="text" placeholder="123-456-7890" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-green-500 outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <input id="inputPassword" type="password" placeholder="••••••••" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-green-500 outline-none transition">
                </div>
                
                <div class="flex justify-between items-center text-sm">
                    <a href="#forgot-password" class="text-orange-600 hover:underline">Forgot password?</a>
                </div>

                <button id="signInButton" type="button" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-lg transition shadow-md">
                    Sign In
                </button>
            </form>

            <div class="mt-6 text-center text-sm text-gray-500">
                Don't have an account? 
                <a href="/account/register" class="text-green-600 font-bold hover:underline">Create an account</a>
            </div>
        </div>
        
        <!-- Bottom Decorative Strip -->
        <div class="h-2 bg-gradient-to-r from-green-500 via-yellow-400 to-orange-500"></div>
    </div>
