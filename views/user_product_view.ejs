<%- include('partials/user_top') %>

<style>
#inputQty::-webkit-outer-spin-button,
#inputQty::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

/* Firefox */
#inputQty{
  -moz-appearance: textfield;
}



/* ── Product page specific styles ───────────────────────────── */

/* Image gallery */
.gallery-main {
  position: relative;
  overflow: hidden;
  border-radius: 16px;
  background: rgba(15,40,15,.5);
  border: 1px solid rgba(255,255,255,.07);
  aspect-ratio: 1 / 1;
  cursor: zoom-in;
}
.gallery-main img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform .4s ease, opacity .25s ease;
}
.gallery-main:hover img { transform: scale(1.06); }

/* Thumbnail strip */
.thumb-item {
  border-radius: 10px;
  overflow: hidden;
  border: 2px solid transparent;
  cursor: pointer;
  aspect-ratio: 1/1;
  background: rgba(15,40,15,.5);
  transition: border-color .2s, transform .2s, opacity .2s;
  flex-shrink: 0;
}
.thumb-item:hover { transform: translateY(-2px); opacity: .85; }
.thumb-item.active { border-color: #fbbf24; }
.thumb-item img { width: 100%; height: 100%; object-fit: cover; }


.variant-btn.active {
  border-color: rgba(34, 197, 94, 0.7); 
  background-color: rgba(34, 197, 94, 0.05); 
}




















/* Info rows */
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 14px 0;
  border-bottom: 1px solid rgba(255,255,255,.05);
  font-size: .82rem;
}
.info-row:last-child { border-bottom: none; }
.info-label { color: #5cb356; min-width: 110px; font-weight: 600; flex-shrink: 0; font-size: .75rem; text-transform: uppercase; letter-spacing: .05em; padding-top: 1px; }

/* Description block */
.desc-content a { color: #fbbf24; }
.desc-content * { font-size: .85rem !important; color: #8fce8a !important; font-family: 'DM Sans', sans-serif !important; }
.desc-content b, .desc-content strong { color: #e0f2df !important; }



/* Stock badge */
.stock-badge-good  { background: rgba(92,179,86,.2); color: #8fce8a; }
.stock-badge-low   { background: rgba(249,115,22,.2); color: #fdba74; }
.stock-badge-out   { background: rgba(239,68,68,.15); color: #f87171; }

/* Sticky right panel on desktop */
@media (min-width:1024px) {
  #productRightPanel { position: sticky; top: 80px; }
}

/* Image nav arrows */
.gallery-arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 34px; height: 34px; border-radius: 50%;
  background: rgba(8,22,9,.6); backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,.12);
  color: #e0f2df;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: background .2s;
  z-index: 5;
}
.gallery-arrow:hover { background: rgba(251,191,36,.3); }
.gallery-arrow.left  { left: 10px; }
.gallery-arrow.right { right: 10px; }

@keyframes fadeImg { from{opacity:0;transform:scale(.98);} to{opacity:1;transform:scale(1);} }
.img-fade { animation: fadeImg .25s ease forwards; }

/* Lightbox */
#lightbox {
  position: fixed; inset: 0; z-index: 500;
  background: rgba(8,22,9,.92); backdrop-filter: blur(10px);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none;
  transition: opacity .25s;
}
#lightbox.open { opacity: 1; pointer-events: all; }
#lightbox img { max-width: 90vw; max-height: 88vh; border-radius: 12px; object-fit: contain; }

</style>

<!-- ══════════════════════════════════════════════════════════
     PRODUCT PAGE
══════════════════════════════════════════════════════════ -->
<div class="mt-6 pb-24 md:pb-10">
<div class="max-w-7xl mx-auto px-4 md:px-6">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-xs text-forest-600 mb-6">
    <a href="/" class="hover:text-harvest-400 transition">Home</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
    <span id="bc-category" class="hover:text-harvest-400 transition cursor-pointer"><%= productData.productCategory %></span>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-forest-400 truncate" id="bc-name"><%= productData.productName %></span>
  </nav>

  <!-- ═══════════════════════════════════
       MAIN GRID  —  gallery | info
  ═══════════════════════════════════ -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10 p-4 bg-white" >

    <!-- ──────────── LEFT: IMAGE GALLERY ──────────── -->
    <div id="galleryColumn">

      <!-- Main image -->
      <div class="gallery-main mb-3" id="galleryMain">
        <button class="gallery-arrow left" id="arrowLeft">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <img id="mainImage" src="<%= productData.productImages[0].imagePath %>" alt="<%= productData.productName %>"/>
        <button class="gallery-arrow right" id="arrowRight">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m9 6 6 6-6 6"/></svg>
        </button>
        <!-- Featured badge -->
         <% if (productData.productFeatured == 'true') { %>
            <div class="absolute top-3 left-3">
              <span class="bg-harvest-400 text-forest-900 text-[10px] font-bold px-2.5 py-1 rounded-full">⭐ Featured</span>
            </div>
          <% }%>

        <div class="absolute top-3 right-3">
          <button class="flex gap-2 bg-harvest-400 text-forest-900 text-[10px] font-bold px-2.5 py-1 rounded-full hover:text-terra-800 transition z-100">
            <svg class="w-4 h-4" id="wishlistIcon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <span id="wishlistLabel">Add to Wishlist</span>
          </button>
        </div>
      </div>

      <!-- Thumbnails -->
      <div class="flex gap-2 overflow-x-auto pb-1" >
        <% productData.productImages.forEach((img,img_idx) => { %>
          <div class="thumb-item w-16 h-16 <%- img_idx === 0 ? 'active' : '' %>">
            <img src="<%= img.imagePath %>" alt="thumb <%= img_idx + 1 %>" />
          </div>
        <% }) %>
      </div>      
    </div>

    <!-- ──────────── RIGHT: PRODUCT INFO ──────────── -->
    <div id="productRightPanel" class="space-y-5">

      <!-- Category pills -->
      <div class="flex items-center gap-2 flex-wrap">
        <span class="badge bg-forest-800 text-forest-300 text-[10px] px-2" ><%= productData.productCategory %></span>
        <span class="badge bg-forest-800 text-forest-300 text-[10px] px-2" ><%= productData.productSubCategory %></span>
        <span class="badge bg-harvest-700 text-harvest-300 text-[10px] px-2" ><%= productData.productSKU %></span>
      </div>

      <!-- Title -->
      <h1 class="font-display text-2xl md:text-3xl font-bold leading-snug" id="infoName"><%= productData.productName %></h1>

      <!-- Price panel -->
      <div class="border-2 border-forest-500/20 bg-forest-600/20 p-5">
        <div class="flex items-end gap-3 flex-wrap" id="priceInfo">
          <% if (productData.productVariants[0].variantSalePrice == 0) { %>
            <span class="text-forest-800 font-bold text-2xl" >₱<%= productData.productVariants[0].variantRegularPrice%></span>
          <% } else {%>
            <span class="text-forest-800 font-bold text-2xl" >₱<%= productData.productVariants[0].variantSalePrice%></span>
            <span class="line-through text-forest-500 text-sm " >₱<%= productData.productVariants[0].variantRegularPrice%></span>
          <% }%>
        </div>
      </div>

      <!-- Guarantee strip -->
      <div class="flex flex-wrap gap-3 text-xs">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-forest-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Quality Guaranteed</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-forest-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          <span>Fast Delivery</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-forest-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          <span>Free Returns</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-forest-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span>100% Fresh & Organic</span>
        </div>
      </div>

      <div class="flex flex-wrap gap-5 text-sm">
        <div class="flex items-center gap-1">
          <span>Variant: </span>
          <span class="text-harvest-700 font-bold" id="variantNameLabel"><%= productData.productVariants[0].variantName %></span>
        </div>
        <div>&bull;</div>

        <div class="flex items-center gap-1">
          <span>Unit: </span>
          <span class="text-harvest-700 font-bold" id="variantUnitLabel"><%= productData.productVariants[0].variantUnit %></span>
        </div>
        <div>&bull;</div>

        <div class="flex items-center gap-1">
          <span>Stocks: </span>
          <span class="text-harvest-700 font-bold" id="variantStocksLabel"><%= productData.productVariants[0].variantStocks %></span>
        </div>

        <div class="flex items-center gap-1">
          <span>Weight: </span>
          <span class="text-harvest-700 font-bold" id="variantWeightLabel"><%= productData.productVariants[0].variantWeight %></span>
        </div>
      </div>



      <div class="mb-3">
        <p class="text-xs font-bold pb-2">Variants</p>
        <div class="flex flex-wrap gap-2">
          <% productData.productVariants.forEach((variant,vrt_idx) => { %>
            <button data-product='<%= productData.productID %>' data-value='<%- JSON.stringify(variant) %>' class="variant-btn <%- vrt_idx === 0 ? 'active' : '' %> border border-gray-300 bg-white px-3 py-1.5 text-sm rounded-md hover:border-forest-400 hover:bg-forest-50 transition">
                <span><%= variant.variantName %></span>
              </button>
            <% }) %>
        </div>
      </div>

      <div>
        <p class="text-xs font-bold pb-2">Quantity</p>
        <div class="flex items-center">
            <button id="qtyMinus"class="w-10 h-10 border border-forest-700/10 hover:border-forest-800">-</button>
            <input id="inputQty" type="number" value="1" min="1" class="w-16 h-10 text-center border border-forest-700/10 appearance-none focus:outline-none"/>
            <button id="qtyPlus" class="w-10 h-10 border border-forest-700/10 hover:border-forest-800">+</button>
        </div>
      </div>

      <!-- ── CTA BUTTONS ── -->
      <div class="flex gap-3">
        <a href="<%= activeUser ? '#' : '/account/login' %>" id="<%= activeUser ? 'addToCart' : '' %>" class="flex flex-1 items-center justify-center gap-2 px-5 py-3.5 border-2 border-forest-500/20 bg-forest-600/20 font-bold text-sm cursor-pointer transition-colors duration-200  hover:bg-forest-100" >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          Add to Cart
        </a>
      </div>

    </div><!-- / right panel -->
  </div><!-- / main grid -->

  <!-- ═══════════════════════════════════
       DESCRIPTION / DETAILS TABS
  ═══════════════════════════════════ -->
  <div class="p-4 bg-white mb-8">

    <p class="text-xs font-bold pb-2">Description</p>
    <span><%- productData.productDescription %></span>
  </div>

</div><!-- /max-w-7xl -->
</div><!-- /min-h-screen -->
<script src="/js/main_app.js" defer ></script>
<script src="/js/user_product_view_app.js" defer ></script>
<%- include('partials/user_bottom') %>
