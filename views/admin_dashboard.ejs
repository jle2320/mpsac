<%- include ('partials/top') %>

    <!-- Welcome bar -->
    <div class="fade-up d1 flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
      <div>
        <h1 class="font-display text-2xl md:text-3xl text-white font-bold">Good morning, <span class="text-harvest-400">Admin</span> 🌾</h1>
