          </div>
        </div>
        <p class="text-forest-400 text-xs mb-1">Ongoing Orders</p>
        <p class="font-display text-2xl text-white font-bold" data-count="4821" id="statOngoingOrders">0</p>
        <p class="text-forest-500 text-[10px] mt-1" id="statPendingOrders">No Order</p>
      </div>

      <!-- Products -->
