                7D
            </button>

            <button class="chart-period text-xs px-3 py-1.5 rounded-lg bg-forest-800/60 text-forest-400 hover:text-harvest-300 transition font-medium" data-period="4w">
                4W
            </button>

            <button class="chart-period text-xs px-3 py-1.5 rounded-lg bg-forest-800/60 text-forest-400 hover:text-harvest-300 transition font-medium" data-period="12m">
                12M
            </button>
        </div>
        </div>
        <div class="chart-wrap" style="height:220px;">
          <canvas id="revenueChart"></canvas>
        </div>
      </div>

      <!-- Quick Actions -->
