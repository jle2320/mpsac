        </div>
        <p class="text-forest-400 text-xs mb-1">Today’s Revenue</p>
        <p class="font-display text-2xl text-white font-bold" data-count="284750" id="todayStatRevenue">₱0</p>
        <p class="text-forest-500 text-[10px] mt-1">vs yesterday revenue (<span id="yesterdayStatRevenue" >₱0</span>)</p>
      </div>

      <!-- Orders -->
      <div class="fade-up d3 glass rounded-2xl p-5 relative overflow-hidden">
