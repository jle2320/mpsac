                <svg class="w-4 h-4 text-harvest-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </div>
              <span class="text-forest-300 text-[11px] font-medium leading-tight">Add Product</span>
            </a>
            <button class="flex flex-col items-center gap-2 bg-forest-800/60 hover:bg-forest-700/50 border border-forest-700/30 rounded-xl p-3 transition text-center group">
