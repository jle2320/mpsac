<%- include ('partials/top') %>
<style>
  *{font-family:'DM Sans',sans-serif;box-sizing:border-box;}
  h1,h2,h3,.font-display{font-family:'Playfair Display',serif;}

  /* grain overlay */
  body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:9999;opacity:.45;}

  ::-webkit-scrollbar{width:5px;height:5px;}
  ::-webkit-scrollbar-track{background:#0e2410;}
  ::-webkit-scrollbar-thumb{background:#2d7429;border-radius:4px;}

  /* sidebar */
  #sidebar{transition:transform .3s cubic-bezier(.22,1,.36,1),width .3s cubic-bezier(.22,1,.36,1);}
  #sidebar.collapsed{width:72px;}
  #sidebar.collapsed .sidebar-label,
  #sidebar.collapsed .sidebar-logo-text,
  #sidebar.collapsed .sidebar-group-label,
  #sidebar.collapsed .sidebar-badge{display:none;}
  #sidebarOverlay{transition:opacity .3s;}

  @keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
  @keyframes pulse2{0%,100%{opacity:1;}50%{opacity:.5;}}
  @keyframes slideIn{from{opacity:0;transform:translateX(14px);}to{opacity:1;transform:translateX(0);}}
  @keyframes modalIn{from{opacity:0;transform:translateY(24px) scale(.97);}to{opacity:1;transform:translateY(0) scale(1);}}
  @keyframes spin{to{transform:rotate(360deg);}}
  @keyframes countUp{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

  .fade-up{animation:fadeUp .5s ease forwards;}
  .d1{animation-delay:.05s;opacity:0;}.d2{animation-delay:.10s;opacity:0;}
  .d3{animation-delay:.15s;opacity:0;}.d4{animation-delay:.20s;opacity:0;}
  .d5{animation-delay:.25s;opacity:0;}.d6{animation-delay:.30s;opacity:0;}

  /* glass */
  .glass{background:rgba(31,75,29,.55);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.07);}

  /* nav */
  .nav-item{display:flex;align-items:center;gap:10px;padding:9px 14px;border-radius:12px;color:#8fce8a;font-size:.825rem;font-weight:500;cursor:pointer;transition:background .18s,color .18s;white-space:nowrap;text-decoration:none;}
  .nav-item:hover{background:rgba(255,255,255,.07);color:#fbbf24;}
  .nav-item.active{background:rgba(251,191,36,.15);color:#fbbf24;border:1px solid rgba(251,191,36,.25);}
  .nav-item svg{flex-shrink:0;}

  /* table */
  .trow{transition:background .15s;cursor:pointer;}
  .trow:hover{background:rgba(251,191,36,.05);}
  .trow.selected{background:rgba(251,191,36,.08);}
  .trow-appear{animation:slideIn .22s ease forwards;opacity:0;}

 

  /* notification dot */
  .notif-dot{width:8px;height:8px;background:#f97316;border-radius:50%;position:absolute;top:6px;right:6px;animation:pulse2 2s infinite;}

  /* modal */
  .modal-backdrop{position:fixed;inset:0;z-index:300;background:rgba(8,22,9,.75);backdrop-filter:blur(6px);display:flex;align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto;opacity:0;pointer-events:none;transition:opacity .25s;}
  .modal-backdrop.open{opacity:1;pointer-events:all;}
  .modal-box{background:#1a4119;border:1px solid rgba(255,255,255,.09);border-radius:20px;width:100%;max-width:700px;box-shadow:0 32px 80px rgba(8,22,9,.55);animation:modalIn .28s ease forwards;margin:auto;}

  /* badge */
  .badge{
    display:inline-flex;
    align-items:center;
    padding:3px 10px;border-radius:99px;
    font-weight:700;
    letter-spacing:.02em;
  }

  /* inputs */
  .search-input{background:rgba(31,75,29,.5);border:1px solid rgba(92,179,86,.2);border-radius:12px;padding:9px 14px 9px 36px;font-size:.8rem;color:#e0f2df;width:100%;transition:border-color .2s;}
  .search-input::placeholder{color:#3a9134;}
  .search-input:focus{outline:none;border-color:rgba(251,191,36,.4);}

  .filter-select{background:rgba(31,75,29,.5);border:1px solid rgba(92,179,86,.2);border-radius:10px;padding:8px 12px;font-size:.78rem;color:#8fce8a;cursor:pointer;transition:border-color .2s;}
  .filter-select:focus{outline:none;border-color:rgba(251,191,36,.4);}
  .filter-select option{background:#1a4119;}

  /* modal input */
  .modal-input{width:100%;background:rgba(15,40,15,.6);border:1.5px solid rgba(92,179,86,.25);border-radius:10px;padding:9px 13px;font-size:.82rem;color:#e0f2df;transition:border-color .2s;}
  .modal-input:focus{outline:none;border-color:rgba(251,191,36,.5);box-shadow:0 0 0 3px rgba(251,191,36,.08);}
  .modal-input::placeholder{color:#3a9134;}
  textarea.modal-input{resize:none;}

  /* prog fill */
  .prog-fill{transition:width 1s cubic-bezier(.22,1,.36,1);}

  /* spinner */
  .spinner{width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;display:inline-block;}


  /* toast */
  #toast{position:fixed;bottom:24px;right:24px;z-index:500;background:#1f4b1d;border:1px solid rgba(92,179,86,.3);border-radius:14px;padding:12px 16px;box-shadow:0 8px 32px rgba(8,22,9,.4);display:flex;align-items:center;gap:10px;font-size:.8rem;color:#e0f2df;transition:opacity .3s,transform .3s;opacity:0;transform:translateY(12px);pointer-events:none;max-width:300px;}
  #toast.show{opacity:1;transform:translateY(0);pointer-events:all;}

  /* stat card hover */
  .stat-card{transition:transform .2s,box-shadow .2s,border-color .2s;}
  .stat-card:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(8,22,9,.3);border-color:rgba(251,191,36,.2);}

  /* order history row */
  .oh-row{transition:background .15s;border-radius:10px;}
  .oh-row:hover{background:rgba(255,255,255,.04);}

  /* responsive sidebar */
  @media(max-width:1023px){
    #sidebar{position:fixed;top:0;left:0;height:100vh;z-index:200;transform:translateX(-100%);width:260px !important;}
    #sidebar.mobile-open{transform:translateX(0);}
    #sidebarOverlay{display:block;}
    #mainContent{margin-left:0 !important;}
  }
  @media(min-width:1024px){
    #sidebarOverlay{display:none !important;}
  }

  /* mobile table col hide */
  @media(max-width:640px){
    .col-join,.col-location,.col-payment{display:none;}
  }
  @media(max-width:480px){
    .col-orders{display:none;}
  }
</style>

<!-- Page title row -->
    <div class="fade-up d1 flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
      <div>
        <h1 class="font-display text-2xl md:text-3xl text-white font-bold">Customer <span class="text-harvest-400">Management</span></h1>
        <p class="text-forest-400 text-sm mt-0.5">View, manage and analyse your customer base.</p>
      </div>
    </div>

    

    <!-- CUSTOMERS TABLE CARD -->
    <div class="fade-up d5 glass rounded-2xl overflow-hidden">

      <!-- Toolbar -->
      <div class="p-4 md:p-5 border-b border-forest-800/50">
        <div class="flex flex-col gap-4">

          <!-- Search + filters -->
          <div class="flex flex-col sm:flex-row gap-3">
            <div class="relative flex-1 max-w-sm">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-forest-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <input id="filterSearch" type="text" placeholder="Name, email, phone" class="search-input"/>
            </div>
            <div class="flex gap-2 flex-wrap">
              <select id="filterSort" class="filter-select">
                <option value="newest">Newest First</option>
                <option value="oldest">Oldest First</option>
                <option value="name-az">Name A-Z</option>
                <option value="name-za">Name Z-A</option>
                <option value="spend-high">Spend: High-Low</option>
                <option value="spend-low">Spend: Low-High</option>
                <option value="orders-high">Orders: High-Low</option>
                <option value="orders-low">Orders: Low-High</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[680px]" id="customersTable">
          <thead>
            <tr class="border-b border-forest-800/60 bg-forest-900/30">
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-4">Customer</th>
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-3">Email</th>
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-3">Phone</th>
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-3 col-join">Joined</th>
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-3 col-orders">Orders</th>
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-3">Total Spend</th>
            </tr>
          </thead>
          <tbody id="customersBody"></tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="px-4 md:px-5 py-4 border-t border-forest-800/40 flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-forest-500 text-xs" id="paginationInfo">Showing 1–10 of 0</p>
        <div class="flex items-center gap-1.5" id="paginationBtns"></div>
      </div>
    </div>

<script src="/js/main_app.js" defer ></script>
<script src="/js/admin_customers_app.js" defer ></script>
<%- include ('partials/bottom') %>