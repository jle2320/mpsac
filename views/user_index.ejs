<style>
  /* ── Product Card ── */
.product-card { position: relative; cursor: pointer; }

/* Image area */
.pc-image-wrap {
  position: relative;
  height: 200px;
  background: #f2f9f2;
  overflow: hidden;
}
.pc-img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform .45s cubic-bezier(.25,.46,.45,.94);
}
.product-card:hover .pc-img { transform: scale(1.06); }

.pc-img-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: #e0f2df;
}

/* New badge (your existing newTag already positions top-right) */
.pc-sale-badge {
  position: absolute; top: 3px; left: 12px;
  background: #d97706; color: #fff;
  font-size: 10px; font-weight: 700;
  letter-spacing: .07em; text-transform: uppercase;
  padding: 3px 8px; border-radius: 20px;
}

/* Hover overlay with view button */
.pc-hover-overlay {
  position: absolute; inset: 0;
  background: rgba(15,40,14,.45);
  backdrop-filter: blur(2px);
  display: flex; align-items: center; justify-content: center;
  opacity: 0;
  transition: opacity .3s ease;
}
.product-card:hover .pc-hover-overlay { opacity: 1; }

.pc-view-btn {
  display: inline-flex; align-items: center; gap: 8px;
  background: #fff; color: #255e22;
  border: none; border-radius: 50px;
  padding: 10px 22px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px; font-weight: 600;
  cursor: pointer;
  box-shadow: 0 8px 24px rgba(8,22,9,.25);
  transform: translateY(6px);
  transition: transform .3s ease, background .2s;
}
.product-card:hover .pc-view-btn { transform: translateY(0); }
.pc-view-btn:hover { background: #f2f9f2; }

/* Body */
.pc-body { padding: 16px 18px 18px; }

.pc-meta {
  display: flex; align-items: center; gap: 4px;
  margin-bottom: 6px;
}
.pc-category {
  font-size: 11px; font-weight: 600;
  letter-spacing: .07em; text-transform: uppercase;
  color: #3a9134;
}
.pc-sub { font-size: 11px; color: #8fce8a; }

.pc-name {
  font-family: 'Playfair Display', serif;
  font-size: 18px; color: #1f4b1d;
  line-height: 1.25; margin-bottom: 10px;
}

/* Variant pills */
.pc-pills-row {
  display: flex; flex-wrap: wrap; gap: 5px;
  margin-bottom: 14px;
}
.pc-pill {
  font-size: 11px; font-weight: 500;
  padding: 3px 10px; border-radius: 20px;
  background: #e0f2df; color: #255e22;
  border: 1px solid #bde4ba;
}
.pc-pill-more {
  background: #fff; color: #8fce8a;
  border-color: #bde4ba;
}

/* Footer */
.pc-footer {
  display: flex; align-items: flex-end; justify-content: space-between;
  gap: 8px;
}
.pc-price {
  font-size: 17px; font-weight: 700;
  color: #1f4b1d;
  font-family: 'DM Sans', sans-serif;
}
.pc-sale-note {
  font-size: 11px; color: #d97706;
  margin-top: 2px;
}
.pc-stock {
  display: flex; align-items: center; gap: 4px;
  font-size: 11.5px; font-weight: 500; color: #5cb356;
  background: #e0f2df; border-radius: 20px;
  padding: 4px 10px; white-space: nowrap;
}
.pc-stock-low { color: #c2410c; background: #ffedd5; }



































/* ── Product Modal ── */
.pm-wrap { display: flex; flex-direction: column; }

.pm-header {
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: 26px 26px 0; gap: 16px;
}
.pm-header-left { flex: 1; min-width: 0; }
.pm-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(20px, 4vw, 28px);
  color: #e0f2df; line-height: 1.2;
}
.pm-sku { margin-top: 4px; font-size: 11.5px; color: #5cb356; letter-spacing: .08em; text-transform: uppercase; }
.pm-close {
  flex-shrink: 0; width: 36px; height: 36px; border-radius: 50%;
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
  color: #bde4ba; font-size: 18px; display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: background .2s, color .2s;
}
.pm-close:hover { background: rgba(255,255,255,.15); color: #fff; }

/* Badges */
.pm-badges { display: flex; flex-wrap: wrap; gap: 7px; padding: 14px 26px 0; }
.pm-badge {
  display: inline-flex; align-items: center; padding: 3px 11px;
  border-radius: 20px; font-size: 11.5px; font-weight: 500; letter-spacing: .04em;
}
.pm-badge-green  { background: rgba(90,179,86,.18); color: #8fce8a; border: 1px solid rgba(90,179,86,.25); }
.pm-badge-yellow { background: rgba(251,191,36,.14); color: #fcd34d; border: 1px solid rgba(251,191,36,.22); }
.pm-badge-gray   { background: rgba(255,255,255,.07); color: #a1c9a0; border: 1px solid rgba(255,255,255,.1); }
.pm-badge-orange { background: rgba(249,115,22,.16); color: #fdba74; border: 1px solid rgba(249,115,22,.22); }

/* Images */
.pm-images {
  display: flex; gap: 10px; padding: 18px 26px;
  overflow-x: auto; scrollbar-width: thin; scrollbar-color: #3a9134 transparent;
}
.pm-images::-webkit-scrollbar { height: 4px; }
.pm-images::-webkit-scrollbar-thumb { background: #3a9134; border-radius: 4px; }
.pm-img-thumb {
  flex-shrink: 0; width: 100px; height: 82px; border-radius: 12px;
  border: 2px solid rgba(255,255,255,.08); background: rgba(255,255,255,.04);
  overflow: hidden; display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: border-color .2s;
}
.pm-img-thumb.active { border-color: #5cb356; }
.pm-img-thumb:hover  { border-color: rgba(90,179,86,.5); }
.pm-img-thumb img    { width: 100%; height: 100%; object-fit: cover; }

/* Divider */
.pm-divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.08) 30%, rgba(255,255,255,.08) 70%, transparent);
  margin: 0 26px;
}

/* Description */
.pm-desc {
  padding: 16px 26px; font-size: 13px; line-height: 1.7; color: #8fce8a;
}
.pm-desc * { color: #8fce8a !important; font-family: 'DM Sans', sans-serif !important; font-size: 13px !important; }

/* Section labels */
.pm-section { padding: 18px 26px 10px; font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: #5cb356; font-weight: 600; }

/* Variant selector */
.pm-variants-row { display: flex; flex-wrap: wrap; gap: 9px; padding: 0 26px 18px; }
.pm-variant-btn {
  display: flex; flex-direction: column; align-items: flex-start;
  padding: 10px 16px; border-radius: 12px; cursor: pointer;
  border: 1.5px solid rgba(255,255,255,.1); background: rgba(255,255,255,.04);
  transition: all .18s; text-align: left;
}
.pm-variant-btn:hover { border-color: rgba(90,179,86,.45); background: rgba(90,179,86,.06); }
.pm-variant-btn.selected {
  border-color: #5cb356; background: rgba(90,179,86,.14);
  box-shadow: 0 0 0 3px rgba(90,179,86,.12);
}
.pm-variant-btn.out-of-stock { opacity: .4; cursor: not-allowed; }
.pv-name  { font-size: 13.5px; font-weight: 600; color: #e0f2df; }
.pv-price { font-size: 12px; color: #5cb356; margin-top: 2px; }
.pv-stock { font-size: 11px; color: #8fce8a; margin-top: 1px; }

/* Selected variant info panel */
.pm-variant-info {
  margin: 0 26px 18px; padding: 14px 16px; border-radius: 14px;
  background: rgba(90,179,86,.07); border: 1px solid rgba(90,179,86,.18);
  display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 12px;
  animation: fadeIn .2s ease;
}
@keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
.pvi-item { display: flex; flex-direction: column; gap: 2px; }
.pvi-label { font-size: 10.5px; letter-spacing: .07em; text-transform: uppercase; color: #5cb356; }
.pvi-value { font-size: 13px; color: #e0f2df; font-weight: 500; }
.pvi-value.sale { color: #fcd34d; }

/* Add to cart zone */
.pm-cart-zone { padding: 0 26px 22px; display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
.pm-qty-wrap {
  display: flex; align-items: center; border-radius: 12px;
  border: 1.5px solid rgba(255,255,255,.12); overflow: hidden;
  background: rgba(255,255,255,.04);
}
.pm-qty-btn {
  width: 38px; height: 42px; display: flex; align-items: center; justify-content: center;
  background: transparent; border: none; color: #8fce8a; font-size: 18px;
  cursor: pointer; transition: background .15s;
}
.pm-qty-btn:hover { background: rgba(255,255,255,.07); }
.pm-qty-input {
  width: 46px; height: 42px; background: transparent; border: none;
  text-align: center; color: #e0f2df; font-size: 15px; font-weight: 600;
  font-family: 'DM Sans', sans-serif;
}
.pm-qty-input::-webkit-inner-spin-button { display: none; }

.pm-add-btn {
  flex: 1; min-width: 150px; height: 44px; border-radius: 12px;
  background: linear-gradient(135deg, #3a9134, #2d7429);
  border: none; color: #fff; font-size: 14px; font-weight: 600;
  font-family: 'DM Sans', sans-serif; cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  transition: opacity .2s, transform .1s, box-shadow .2s;
  box-shadow: 0 4px 16px rgba(58,145,52,.35);
}
.pm-add-btn:hover:not(:disabled) { opacity: .92; box-shadow: 0 6px 22px rgba(58,145,52,.45); }
.pm-add-btn:active:not(:disabled) { transform: scale(.98); }
.pm-add-btn:disabled { opacity: .35; cursor: not-allowed; box-shadow: none; }
.pm-add-btn.success { background: linear-gradient(135deg, #255e22, #1f4b1d); }

.pm-select-hint {
  width: 100%; font-size: 12px; color: #5cb356; opacity: .7; text-align: center; padding-top: 2px;
}

/* Footer timestamps */
.pm-footer {
  padding: 14px 26px; border-top: 1px solid rgba(255,255,255,.06);
  display: flex; flex-wrap: wrap; gap: 10px 24px;
}
.pm-ts { font-size: 11.5px; color: #5cb356; }
.pm-ts span { color: #8fce8a; margin-left: 4px; }

/* Responsive */
@media (max-width: 480px) {
  .pm-header, .pm-badges, .pm-images, .pm-desc,
  .pm-section, .pm-variants-row, .pm-variant-info,
  .pm-cart-zone, .pm-footer { padding-left: 16px; padding-right: 16px; }
  .pm-divider { margin: 0 16px; }
  .pm-variant-info { grid-template-columns: repeat(2, 1fr); }
  .pm-variant-btn { padding: 9px 13px; }
}














</style>




