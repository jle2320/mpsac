<%- include ('partials/top') %>

<style>
  *{font-family:'DM Sans',sans-serif;box-sizing:border-box;}
  h1,h2,h3,.font-display{font-family:'Playfair Display',serif;}

  /* grain overlay */
  body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:9999;opacity:.45;}

  ::-webkit-scrollbar{width:5px;height:5px;}
  ::-webkit-scrollbar-track{background:#0e2410;}
  ::-webkit-scrollbar-thumb{background:#2d7429;border-radius:4px;}

  /* sidebar */
  #sidebar{transition:transform .3s cubic-bezier(.22,1,.36,1),width .3s cubic-bezier(.22,1,.36,1);}
  #sidebar.collapsed{width:72px;}
  #sidebar.collapsed .sidebar-label,
  #sidebar.collapsed .sidebar-logo-text,
  #sidebar.collapsed .sidebar-group-label,
  #sidebar.collapsed .sidebar-badge{display:none;}
  #sidebarOverlay{transition:opacity .3s;}

  @keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
  @keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
  @keyframes pulse2{0%,100%{opacity:1;}50%{opacity:.5;}}
  @keyframes slideInRight{from{opacity:0;transform:translateX(18px);}to{opacity:1;transform:translateX(0);}}
  @keyframes modalIn{from{opacity:0;transform:translateY(24px) scale(.97);}to{opacity:1;transform:translateY(0) scale(1);}}
  @keyframes spin{to{transform:rotate(360deg);}}

  .fade-up{animation:fadeUp .5s ease forwards;}
  .d1{animation-delay:.05s;opacity:0;}.d2{animation-delay:.10s;opacity:0;}
  .d3{animation-delay:.15s;opacity:0;}.d4{animation-delay:.20s;opacity:0;}
  .d5{animation-delay:.25s;opacity:0;}.d6{animation-delay:.30s;opacity:0;}

  /* glass */
  .glass{background:rgba(31,75,29,.55);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.07);}

  /* nav */
  .nav-item{display:flex;align-items:center;gap:10px;padding:9px 14px;border-radius:12px;color:#8fce8a;font-size:.825rem;font-weight:500;cursor:pointer;transition:background .18s,color .18s;white-space:nowrap;text-decoration:none;}
  .nav-item:hover{background:rgba(255,255,255,.07);color:#fbbf24;}
  .nav-item.active{background:rgba(251,191,36,.15);color:#fbbf24;border:1px solid rgba(251,191,36,.25);}
  .nav-item svg{flex-shrink:0;}

  /* table */
  .trow{transition:background .15s;cursor:pointer;}
  .trow:hover{background:rgba(251,191,36,.05);}
  .trow.selected{background:rgba(251,191,36,.08);}


  /* notification dot */
  .notif-dot{width:8px;height:8px;background:#f97316;border-radius:50%;position:absolute;top:6px;right:6px;animation:pulse2 2s infinite;}

 

  /* order row slide-in on tab switch */
  .trow-appear{animation:slideInRight .22s ease forwards;}

  /* pill badge */
  .badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:99px;font-size:.65rem;font-weight:700;letter-spacing:.02em;}

  /* timeline */
  .tl-dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .tl-line{width:2px;flex:1;min-height:20px;}

  /* progress fill */
  .prog-fill{transition:width 1s cubic-bezier(.22,1,.36,1);}

  /* spinner */
  .spinner{width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;display:inline-block;}

  /* search input */
  .search-input{background:rgba(31,75,29,.5);border:1px solid rgba(92,179,86,.2);border-radius:12px;padding:9px 14px 9px 36px;font-size:.8rem;color:#e0f2df;width:100%;transition:border-color .2s;}
  .search-input::placeholder{color:#3a9134;}
  .search-input:focus{outline:none;border-color:rgba(251,191,36,.4);}

  /* select */
  .filter-select{background:rgba(31,75,29,.5);border:1px solid rgba(92,179,86,.2);border-radius:10px;padding:8px 12px;font-size:.78rem;color:#8fce8a;cursor:pointer;transition:border-color .2s;}
  .filter-select:focus{outline:none;border-color:rgba(251,191,36,.4);}
  .filter-select option{background:#1a4119;}

  /* toast */
  #toast{position:fixed;bottom:24px;right:24px;z-index:500;background:#1f4b1d;border:1px solid rgba(92,179,86,.3);border-radius:14px;padding:12px 16px;box-shadow:0 8px 32px rgba(8,22,9,.4);display:flex;align-items:center;gap:10px;font-size:.8rem;color:#e0f2df;transition:opacity .3s,transform .3s;opacity:0;transform:translateY(12px);pointer-events:none;max-width:300px;}
  #toast.show{opacity:1;transform:translateY(0);pointer-events:all;}

  /* responsive sidebar */
  @media(max-width:1023px){
    #sidebar{position:fixed;top:0;left:0;height:100vh;z-index:200;transform:translateX(-100%);width:260px !important;}
    #sidebar.mobile-open{transform:translateX(0);}
    #sidebarOverlay{display:block;}
    #mainContent{margin-left:0 !important;}
  }
  @media(min-width:1024px){
    #sidebarOverlay{display:none !important;}
  }

  /* mobile table: hide low-priority cols */
  @media(max-width:640px){
    .col-date,.col-payment,.col-farmer{display:none;}
  }
  @media(max-width:480px){
    .col-items{display:none;}
  }





















/* ── View product ── */
.pm-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    padding: 28px 28px 0;
    gap: 16px;
  }
  .pm-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(22px, 4vw, 30px);
    color: #e0f2df;
    line-height: 1.2;
  }
  .pm-sku {
    margin-top: 4px;
    font-size: 12px; color: #5cb356;
    letter-spacing: .08em; text-transform: uppercase;
  }
  .pm-close {
    flex-shrink: 0;
    width: 36px; height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    color: #bde4ba; font-size: 18px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .2s, color .2s;
  }
  .pm-close:hover { background: rgba(255,255,255,.14); color: #fff; }

  /* ── Badges row ── */
  .pm-badges {
    display: flex; flex-wrap: wrap; gap: 8px;
    padding: 16px 28px 0;
  }
  .badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 11px; border-radius: 20px;
    font-size: 12px; font-weight: 500; letter-spacing: .04em;
  }
  .badge-green  { background: rgba(90,179,86,.18); color: #8fce8a; border: 1px solid rgba(90,179,86,.25); }
  .badge-yellow { background: rgba(251,191,36,.14); color: #fcd34d; border: 1px solid rgba(251,191,36,.22); }
  .badge-gray   { background: rgba(255,255,255,.07); color: #a1c9a0; border: 1px solid rgba(255,255,255,.1); }
  .badge-orange { background: rgba(249,115,22,.16); color: #fdba74; border: 1px solid rgba(249,115,22,.22); }

  /* ── Image strip ── */
  .pm-images {
    display: flex; gap: 10px;
    padding: 20px 28px;
    overflow-x: auto;
    scrollbar-width: thin; scrollbar-color: #3a9134 transparent;
  }
  .pm-images::-webkit-scrollbar { height: 4px; }
  .pm-images::-webkit-scrollbar-thumb { background: #3a9134; border-radius: 4px; }
  .pm-img-thumb {
    flex-shrink: 0;
    width: 110px; height: 90px;
    border-radius: 12px;
    border: 2px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.04);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    transition: border-color .2s;
  }
  .pm-img-thumb:hover { border-color: #5cb356; }
  .pm-img-thumb img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .pm-img-placeholder {
    width: 38px; height: 38px; opacity: .25;
  }

  /* ── Divider ── */
  .pm-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.08) 30%, rgba(255,255,255,.08) 70%, transparent);
    margin: 0 28px;
  }

  /* ── Description ── */
  .pm-desc {
    padding: 20px 28px;
    font-size: 13.5px; line-height: 1.65;
    color: #8fce8a;
  }
  .pm-desc * { color: #8fce8a !important; font-family: 'DM Sans', sans-serif !important; font-size: 13.5px !important; }

  /* ── Section label ── */
  .pm-section-label {
    padding: 0 28px 12px;
    font-size: 11px; letter-spacing: .12em;
    text-transform: uppercase; color: #5cb356;
    font-weight: 600;
  }

  /* ── Variants grid ── */
  .pm-variants {
    padding: 0 28px 24px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
  }
  .variant-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 14px;
    padding: 16px;
    transition: border-color .2s, background .2s;
  }
  .variant-card:hover {
    border-color: rgba(90,179,86,.35);
    background: rgba(90,179,86,.05);
  }
  .vc-name {
    font-family: 'Playfair Display', serif;
    font-size: 16px; color: #e0f2df;
    margin-bottom: 10px;
  }
  .vc-row {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 6px;
  }
  .vc-label { font-size: 11px; color: #5cb356; letter-spacing: .05em; text-transform: uppercase; }
  .vc-value { font-size: 13px; color: #bde4ba; font-weight: 500; }
  .vc-price-regular { font-size: 18px; color: #e0f2df; font-weight: 600; }
  .vc-price-sale {
    font-size: 13px; color: #fcd34d; font-weight: 500;
    background: rgba(251,191,36,.12); border-radius: 6px;
    padding: 2px 7px;
  }
  .vc-price-cost { font-size: 12px; color: #8fce8a; }
  .vc-stocks {
    margin-top: 10px; padding-top: 10px;
    border-top: 1px solid rgba(255,255,255,.07);
    display: flex; align-items: center; justify-content: space-between;
  }
  .vc-stock-num { font-size: 20px; font-weight: 700; color: #5cb356; }
  .vc-stock-unit { font-size: 11px; color: #8fce8a; }
  .vc-expiry {
    font-size: 11px; color: #fdba74;
    margin-top: 8px;
    display: flex; align-items: center; gap: 4px;
  }

  /* ── Stock movements ── */
  .pm-movements { padding: 0 28px 28px; }
  .movement-table {
    width: 100%; border-collapse: collapse;
    font-size: 13px;
  }
  .movement-table thead tr {
    background: rgba(255,255,255,.04);
  }
  .movement-table th {
    text-align: left; padding: 9px 12px;
    font-size: 11px; letter-spacing: .08em;
    text-transform: uppercase; color: #5cb356;
    font-weight: 600;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .movement-table td {
    padding: 9px 12px; color: #bde4ba;
    border-bottom: 1px solid rgba(255,255,255,.05);
    vertical-align: middle;
  }
  .movement-table tr:last-child td { border-bottom: none; }
  .movement-table tr:hover td { background: rgba(255,255,255,.03); }
  .mt-variant-badge {
    display: inline-block;
    background: rgba(90,179,86,.15); color: #8fce8a;
    border-radius: 6px; padding: 2px 8px;
    font-size: 11px; font-weight: 500;
  }
  .mt-type {
    display: inline-flex; align-items: center; gap: 4px;
    background: rgba(90,179,86,.12); color: #5cb356;
    border-radius: 6px; padding: 3px 9px;
    font-size: 11px; text-transform: capitalize; font-weight: 500;
  }
  .mt-qty { font-weight: 600; color: #e0f2df; }

  /* ── Timestamps footer ── */
  .pm-footer {
    padding: 16px 28px;
    border-top: 1px solid rgba(255,255,255,.06);
    display: flex; flex-wrap: wrap; gap: 12px 28px;
  }
  .pm-ts { font-size: 11.5px; color: #5cb356; }
  .pm-ts span { color: #8fce8a; margin-left: 4px; }

  /* ── Responsive ── */
  @media (max-width: 500px) {
    .pm-header, .pm-badges, .pm-images, .pm-desc,
    .pm-section-label, .pm-variants, .pm-movements, .pm-footer {
      padding-left: 18px; padding-right: 18px;
    }
    .pm-divider { margin: 0 18px; }
    .movement-table { font-size: 12px; }
    .movement-table th, .movement-table td { padding: 8px 8px; }
  }











</style>

<!-- Page title row -->
    <div class="fade-up d1 flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
      <div>
        <h1 class="font-display text-2xl md:text-3xl text-white font-bold">Product <span class="text-harvest-400">Management</span></h1>
        <p class="text-forest-400 text-sm mt-0.5">Manage, and update all products.</p>
      </div>
      <div class="flex gap-2">
        <a href="/a/products/new" class="flex items-center gap-1.5 bg-harvest-400 hover:bg-harvest-300 text-forest-900 text-xs font-bold px-3.5 py-2 rounded-xl transition">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Product
        </a>
      </div>
    </div>

    

    <!-- ORDERS TABLE CARD -->
    <div class="fade-up d5 glass rounded-2xl overflow-hidden">

      <!-- Table toolbar -->
      <div class="p-4 md:p-5 border-b border-forest-800/50">
        <div class="flex flex-col gap-4">

          <!-- Filters row -->
          <div class="flex flex-col sm:flex-row gap-3">
            <div class="relative flex-1 max-w-sm">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-forest-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <input id="filterSearch" type="text" placeholder="Search product name or product SKU" class="search-input"/>
            </div>
            <div class="flex gap-2 flex-wrap">
              <select id="filterCategory" class="filter-select">
                <option value="all">All Category</option>
              </select>
            </div>
            <div class="flex gap-2 flex-wrap">
              <select id="filterStatus" class="filter-select">
                <option value="all">All Status</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="overflow-x-auto">
        <table class="w-full text-sm min-w-[700px]" id="ordersTable">
          <thead>
            <tr class="border-b border-forest-800/60 bg-forest-900/30">
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-4">Product SKU</th>
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-3">Product Name</th>
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-3">Category</th>
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-3">Status</th>
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-3">Variants</th>
              <th class="text-left text-forest-500 text-[10px] font-bold uppercase tracking-wider py-3.5 px-3">Stocks</th>
            </tr>
          </thead>
          <tbody id="productsTbody"></tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="px-4 md:px-5 py-4 border-t border-forest-800/40 flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="text-forest-500 text-xs" id="paginationInfo">Showing 1–10 of 47</p>
        <div class="flex items-center gap-1.5" id="paginationBtns"></div>
      </div>
    </div>

