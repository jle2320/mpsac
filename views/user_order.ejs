<%- include('partials/user_top') %>

<style>


  /* ── Tab bar ── */
  .orders-tabs {
    display: flex;
    align-items: center;
    gap: 0;
    background: #fff;
    border-bottom: 2px solid #e0f2df;
    overflow-x: auto;
    scrollbar-width: none;
    position: sticky;
    top: 64px;
    z-index: 40;
    box-shadow: 0 2px 12px rgba(45,116,41,.08);
  }
  .orders-tabs::-webkit-scrollbar { display: none; }

  .tab-btn {
    padding: 14px 22px;
    font-size: .82rem;
    font-weight: 600;
    color: #5cb356;
    white-space: nowrap;
    cursor: pointer;
    border: none;
    background: transparent;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: color .2s, border-color .2s;
    position: relative;
    font-family: 'DM Sans', sans-serif;
  }
  .tab-btn:hover { color: #2d7429; }
  .tab-btn.active {
    color: #f59e0b;
    border-bottom-color: #f59e0b;
    font-weight: 700;
  }
  .tab-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #f97316;
    color: #fff;
    font-size: 10px;
    font-weight: 800;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    margin-left: 5px;
    vertical-align: middle;
  }

  /* ── Search bar ── */
  .orders-search {
    background: #fff;
    border: 1.5px solid #e0f2df;
    border-radius: 10px;
    padding: 10px 14px 10px 38px;
    font-size: .83rem;
    color: #183d17;
    width: 100%;
    transition: border-color .2s, box-shadow .2s;
    font-family: 'DM Sans', sans-serif;
  }
  .orders-search::placeholder { color: #8fce8a; }
  .orders-search:focus {
    outline: none;
    border-color: #2d7429;
    box-shadow: 0 0 0 3px rgba(45,116,41,.1);
  }

  /* ── Order card ── */
  .order-card {
    background: #fff;
    border-radius: 16px;
    border: 1.5px solid #e0f2df;
    overflow: hidden;
    margin-bottom: 16px;
    transition: box-shadow .2s, border-color .2s;
    box-shadow: 0 2px 10px rgba(45,116,41,.06);
  }
  .order-card:hover {
    box-shadow: 0 6px 24px rgba(45,116,41,.12);
    border-color: #bde4ba;
  }

  /* ── Seller header ── */
  .seller-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 18px;
    border-bottom: 1.5px solid #f2f9f2;
    background: #f9fcf9;
    flex-wrap: wrap;
    gap: 8px;
  }
  .seller-left {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .seller-icon {
    width: 30px;
    height: 30px;
    background: #e0f2df;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .seller-name {
    font-size: .85rem;
    font-weight: 700;
    color: #183d17;
    font-family: 'DM Sans', sans-serif;
  }
  .btn-chat {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: #f97316;
    color: #fff;
    font-size: .72rem;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: background .2s;
    font-family: 'DM Sans', sans-serif;
  }
  .btn-chat:hover { background: #ea580c; }
  .btn-view-shop {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: transparent;
    color: #2d7429;
    font-size: .72rem;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 8px;
    border: 1.5px solid #bde4ba;
    cursor: pointer;
    transition: all .2s;
    font-family: 'DM Sans', sans-serif;
    text-decoration: none;
  }
  .btn-view-shop:hover { background: #f2f9f2; border-color: #2d7429; }

  /* ── Status right ── */
  .order-status-label {
    font-size: .78rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .status-to-receive { color: #f97316; }
  .status-to-ship    { color: #fbbf24; }
  .status-to-pay     { color: #ea580c; }
  .status-completed  { color: #2d7429; }
  .status-cancelled  { color: #9ca3af; }
  .status-refund     { color: #7c2d12; }

  /* ── Tracking info ── */
  .tracking-info {
    font-size: .73rem;
    color: #5cb356;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  /* ── Product row ── */
  .product-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 18px;
    border-bottom: 1px solid #f2f9f2;
    transition: background .15s;
  }
  .product-row:hover { background: #f9fcf9; }
  .product-row:last-of-type { border-bottom: none; }

  .product-img-wrap {
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    border: 1.5px solid #e0f2df;
    background: #f2f9f2;
  }
  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-info { flex: 1; min-width: 0; }
  .product-name {
    font-size: .85rem;
    font-weight: 600;
    color: #183d17;
    margin: 0 0 3px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
    font-family: 'DM Sans', sans-serif;
  }
  .product-variation {
    font-size: .75rem;
    color: #5cb356;
    margin: 0 0 4px;
  }
  .product-qty {
    font-size: .75rem;
    color: #8fce8a;
  }
  .product-price-col {
    text-align: right;
    flex-shrink: 0;
    padding-top: 2px;
  }
  .product-price-original {
    font-size: .75rem;
    color: #bde4ba;
    text-decoration: line-through;
    display: block;
  }
  .product-price-final {
    font-size: .9rem;
    font-weight: 700;
    color: #f97316;
    font-family: 'Playfair Display', serif;
  }

  /* ── Order footer ── */
  .order-footer {
    padding: 12px 18px;
    border-top: 1.5px solid #f2f9f2;
    background: #f9fcf9;
  }
  .order-total-row {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    margin-bottom: 10px;
  }
  .order-total-label {
    font-size: .82rem;
    color: #5cb356;
    font-weight: 500;
  }
  .order-total-amount {
    font-size: 1.1rem;
    font-weight: 700;
    color: #f97316;
    font-family: 'Playfair Display', serif;
  }


  .action-btns {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* ── Action buttons ── */
  .btn-primary-order {
    padding: 9px 20px;
    background: linear-gradient(135deg, #fbbf24, #f59e0b);
    color: #183d17;
    font-size: .78rem;
    font-weight: 800;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    transition: all .2s;
    box-shadow: 0 2px 10px rgba(251,191,36,.3);
    font-family: 'DM Sans', sans-serif;
    white-space: nowrap;
  }
  .btn-primary-order:hover {
    filter: brightness(1.05);
    box-shadow: 0 4px 16px rgba(251,191,36,.4);
    transform: translateY(-1px);
  }
  .btn-secondary-order {
    padding: 9px 18px;
    background: transparent;
    color: #2d7429;
    font-size: .78rem;
    font-weight: 600;
    border-radius: 10px;
    border: 1.5px solid #bde4ba;
    cursor: pointer;
    transition: all .2s;
    font-family: 'DM Sans', sans-serif;
    white-space: nowrap;
  }
  .btn-secondary-order:hover {
    background: #f2f9f2;
    border-color: #2d7429;
  }
  .btn-danger-order {
    padding: 9px 18px;
    background: transparent;
    color: #ea580c;
    font-size: .78rem;
    font-weight: 600;
    border-radius: 10px;
    border: 1.5px solid #fed7aa;
    cursor: pointer;
    transition: all .2s;
    font-family: 'DM Sans', sans-serif;
    white-space: nowrap;
  }
  .btn-danger-order:hover {
    background: #fff7ed;
    border-color: #ea580c;
  }

  /* ── Empty state ── */
  .empty-orders {
    text-align: center;
    padding: 64px 20px;
    color: #8fce8a;
    transition: box-shadow .2s, border-color .2s;
    box-shadow: 0 2px 10px rgba(45,116,41,.06);
  }
  .empty-orders svg { opacity: .3; margin: 0 auto 16px; display: block; }
  .empty-orders h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: #2d7429;
    margin-bottom: 6px;
  }
  .empty-orders p { font-size: .85rem; }

  /* ── Animations ── */
  @keyframes fadeUpOrder {
    from { opacity:0; transform:translateY(16px); }
    to   { opacity:1; transform:translateY(0); }
  }
  .order-card { animation: fadeUpOrder .4s ease forwards; opacity: 0; }
  .empty-orders { animation: fadeUpOrder .4s ease forwards; opacity: 0; }
  /* ── Responsive ── */
  @media (max-width: 640px) {
    .tab-btn { padding: 12px 14px; font-size: .76rem; }
    .seller-bar { padding: 10px 14px; }
    .product-row { padding: 12px 14px; }
    .order-footer { padding: 10px 14px; }
    .product-img-wrap { width: 60px; height: 60px; }
    .order-total-row { justify-content: flex-end; }
    .btn-primary-order, .btn-secondary-order, .btn-danger-order { padding: 8px 14px; font-size: .74rem; }
  }
</style>















<section class="max-w-7xl mx-auto px-6 py-14">
  <div class="mb-8">
    <h1 class="font-display text-4xl text-forest-900">Orders</h1>
    <p class="text-forest-500 font-body">Check your cart</p>
  </div>

  <div class="grid grid-cols-1 gap-8" >


    <!-- ── TAB BAR ── -->
    <div class="orders-tabs rounded-t-2xl mb-0 overflow-hidden">
      <button class="tab-btn active" id="allBtn" data-status="all">All</button>
      <button class="tab-btn" id="pendingBtn" data-status="pending">Pending</button>
      <button class="tab-btn" id="toShipBtn" data-status="to_ship">To Ship</button>
      <button class="tab-btn" id="toReiveBtn" data-status="to_receive">To Receive</button>
      <button class="tab-btn" id="completeBtn" data-status="completed">Completed</button>
      <button class="tab-btn" id="cancelBtn" data-status="cancelled">Cancelled</button>
      <button class="tab-btn" id="returnBtn" data-status="refund">Return/Refund</button>
    </div>

    <!-- ── SEARCH BAR ── -->
    <div class="bg-white px-4 py-3 border-x border-b border-forest-100 mb-5 rounded-b-2xl shadow-sm">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-forest-400 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" id="orderSearch" placeholder="Search by Order Number or Product name" class="orders-search" />
      </div>
    </div>

    <div id="emptyState" class="hidden empty-orders bg-white rounded-2xl border border-forest-100">
      <svg width="72" height="72" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24">
          <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
          <rect x="9" y="3" width="6" height="4" rx="1"/>
          <line x1="9" y1="12" x2="15" y2="12"/>
          <line x1="9" y1="16" x2="13" y2="16"/>
      </svg>
      <h3>No orders found</h3>
      <p>Try a different tab or search term.</p>
    </div>

    <div id="ordersList"></div>

  </div>
</section>











<script src="/js/main_app.js" defer ></script>
<script src="/js/user_order_app.js" defer ></script>
<%- include('partials/user_bottom') %>
